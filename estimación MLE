#   EJECUTAR PARA LAS 3 VARIABLES
# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
par(mfrow = c(1, 3))   # 3 grГЎficas lado a lado

analizar(datos$PESO.TOTAL,      "PESO TOTAL")
analizar(datos$PESO.INTERNO,    "PESO INTERNO")
analizar(datos$PESO.SUPERFICIE, "PESO SUPERFICIE")

par(mfrow = c(1, 1))   # restaurar

